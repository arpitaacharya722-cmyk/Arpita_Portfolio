# ── Local dev server ─────────────────────────────────────────────────────────
# These are set automatically when running on Replit.
# When running locally, the defaults (PORT=3000, BASE_PATH=/) are used automatically
# so you don't need to set these unless you want a different port.
PORT=3000
BASE_PATH=/

# ── EmailJS — contact form email delivery ────────────────────────────────────
# Sign up free at https://www.emailjs.com (200 emails/month)
# 1. Create an Email Service  →  copy the Service ID  (e.g. service_abc123)
# 2. Create an Email Template →  copy the Template ID (e.g. template_abc123)
#    Use these variables in your template body:
#      {{from_name}}  {{from_email}}  {{subject}}  {{message}}
# 3. Account → copy your Public Key
VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxx
VITE_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxx
